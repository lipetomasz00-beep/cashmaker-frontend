<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Twój wynik</title>

<style>

body{
  margin:0;
  font-family:Arial;
  background:#0b0b0f;
  color:white;
  text-align:center;
  padding:30px 20px;
}

/* BOX */

.box{
  background:#12121a;
  border-radius:20px;
  padding:30px;
  box-shadow:0 0 30px rgba(255,0,0,0.3);
}

/* STATUS */

.status{
  font-size:22px;
  margin-bottom:15px;
}

.good{
  color:#22c55e;
}

/* SCORE */

.score{
  font-size:40px;
  margin:20px 0;
  color:#22c55e;
}

/* OFFER */

.offer{
  font-size:18px;
  margin:15px 0;
  opacity:0.9;
}

/* CTA */

button{
  margin-top:25px;
  padding:18px 25px;
  font-size:18px;
  background:#ef4444;
  border:none;
  border-radius:12px;
  color:white;
  cursor:pointer;
  box-shadow:0 0 20px rgba(255,0,0,0.6);
}

/* TIMER */

.timer{
  margin-top:15px;
  font-size:14px;
  opacity:0.7;
}

</style>

</head>

<body>

<div class="box">

  <div class="status good">
    ✔ Analiza zakończona
  </div>

  <div>
    Dopasowaliśmy ofertę dla Ciebie
  </div>

  <div class="score">
    87% szansy na akceptację
  </div>

  <div class="offer">
    💸 Pożyczka do 10 000 zł  
    🕒 Decyzja nawet dziś  
  </div>

  <button onclick="goOffer()">
    👉 Przejdź do decyzji
  </button>

  <div class="timer">
    ⏱ Oferta dostępna przez <span id="time">09:59</span>
  </div>

</div>

<script>

/* TIMER */
let sec = 599

setInterval(()=>{
  sec--
  let m = Math.floor(sec/60)
  let s = sec%60
  document.getElementById("time").innerText =
    `${m}:${s<10?'0':''}${s}`
},1000)

/* REDIRECT */
function goOffer(){
  const params = window.location.search
  window.location.href = "/go" + params
}

</script>

</body>
</html>